# ── Required ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Claude API key (for KelliAI chat)

# ── Optional but recommended ────────────────────────────────────────────────
ELEVENLABS_API_KEY=...                # ElevenLabs key (KelliAI voice)
ELEVENLABS_VOICE_ID=...              # ElevenLabs voice ID

DATABASE_URL=postgresql://user:pass@host:5432/dbname   # Postgres (lead capture)
ADMIN_API_KEY=your-secret-key        # Protects /api/kelliai/leads endpoint

# ── KelliAI integration ────────────────────────────────────────────────────
# Build-time only. Leave unset to use the same-origin "/api" routes shipped
# with this server. Set to an absolute URL (no trailing slash) to point the
# client at a separately hosted KelliAI backend, e.g.:
#   VITE_API_URL=https://kelliai.balancedmedicalspa.com/api
VITE_API_URL=

# ── Booking / scheduling URLs (build-time, per location) ───────────────────
# Each location has its own optional scheduling URL (Podium, NexHealth,
# whatever the practice uses). When set, "Book at <city>" buttons deep-link
# straight to that location's calendar.
#
# If a per-location URL is missing, the site falls back to
# VITE_PODIUM_BOOKING_URL. If that's also missing, it falls back to the
# legacy single-tenant Podium URL (which today shows no availability) so
# links don't 404. Either way, the location chooser dialog and contact form
# always surface call/text fallbacks.
#
# Examples (replace with the URL Podium gives you per location):
#   VITE_PODIUM_BOOKING_URL_KINGSPORT=https://booking.podium.com/medspa/<kingsport-id>
#   VITE_PODIUM_BOOKING_URL_JONESBOROUGH=https://booking.podium.com/medspa/<jonesborough-id>
VITE_PODIUM_BOOKING_URL_KINGSPORT=
VITE_PODIUM_BOOKING_URL_JONESBOROUGH=
# Optional shared/fallback URL used when a per-location URL isn't set:
VITE_PODIUM_BOOKING_URL=

# ── Server / deploy ────────────────────────────────────────────────────────
ALLOWED_ORIGIN=*                     # CORS allowlist; set to https://balancedmedicalspa.com in prod
CANONICAL_HOST=balancedmedicalspa.com # Apex host; www.* requests are 301'd here

# ── Railway sets this automatically ─────────────────────────────────────────
PORT=3000
