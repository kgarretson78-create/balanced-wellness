# ── Required ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Claude API key (for KelliAI chat)

# ── Optional but recommended ────────────────────────────────────────────────
ELEVENLABS_API_KEY=...                # ElevenLabs key (KelliAI voice)
ELEVENLABS_VOICE_ID=...              # ElevenLabs voice ID

DATABASE_URL=postgresql://user:pass@host:5432/dbname   # Postgres (lead capture)
ADMIN_API_KEY=your-secret-key        # Protects /api/kelliai/leads endpoint

# ── KelliAI integration ────────────────────────────────────────────────────
# Build-time only. Leave unset to use the same-origin "/api" routes shipped
# with this server. Set to an absolute URL (no trailing slash) to point the
# client at a separately hosted KelliAI backend, e.g.:
#   VITE_API_URL=https://kelliai.balancedmedicalspa.com/api
VITE_API_URL=

# ── Booking / location chooser ─────────────────────────────────────────────
# Per-location Podium booking URLs. Each "Book Now" button opens a chooser
# (Kingsport vs. Jonesborough); when the user picks a location, we open the
# matching URL below in a new tab. If a per-location URL is missing/blank,
# we fall back to VITE_PODIUM_BOOKING_URL (or the legacy shared URL baked
# into src/lib/booking.ts) so the chooser always opens *something*. The
# chooser also surfaces call/text buttons for both clinics so users are
# never stranded by a Podium calendar with no available days/times.
#
# When you provision distinct per-location calendars in Podium, paste the
# URLs below and redeploy.
VITE_PODIUM_BOOKING_URL_KINGSPORT=
VITE_PODIUM_BOOKING_URL_JONESBOROUGH=
VITE_PODIUM_BOOKING_URL=

# ── Server / deploy ────────────────────────────────────────────────────────
ALLOWED_ORIGIN=*                     # CORS allowlist; set to https://balancedmedicalspa.com in prod
CANONICAL_HOST=balancedmedicalspa.com # Apex host; www.* requests are 301'd here

# ── Railway sets this automatically ─────────────────────────────────────────
PORT=3000
