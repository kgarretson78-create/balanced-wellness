# ── Required ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Claude API key (for KelliAI chat)

# ── Optional but recommended ────────────────────────────────────────────────
ELEVENLABS_API_KEY=...                # ElevenLabs key (KelliAI voice)
ELEVENLABS_VOICE_ID=...              # ElevenLabs voice ID

DATABASE_URL=postgresql://user:pass@host:5432/dbname   # Postgres (lead capture)
ADMIN_API_KEY=your-secret-key        # Protects /api/kelliai/leads endpoint

# ── KelliAI integration ────────────────────────────────────────────────────
# Build-time only. Leave unset to use the same-origin "/api" routes shipped
# with this server. Set to an absolute URL (no trailing slash) to point the
# client at a separately hosted KelliAI backend, e.g.:
#   VITE_API_URL=https://kelliai.balancedmedicalspa.com/api
VITE_API_URL=

# ── Booking / scheduling URLs (build-time, per location) ───────────────────
# Each location has a real, dedicated Podium scheduling URL hardcoded as a
# default in src/lib/booking.ts:
#   Kingsport     → https://booking.podium.com/medspa/01930831-564b-7342-98d8-620e43a707e7
#   Jonesborough  → https://booking.podium.com/medspa/019c25c3-bfb8-7652-9b53-3b7f41adc505
#
# The env vars below are optional overrides. Set them in Railway only if you
# want to swap a location's link without a code change. Precedence:
#   1. VITE_PODIUM_BOOKING_URL_<LOCATION>   (per-location override)
#   2. Hardcoded default in src/lib/booking.ts
#   3. VITE_PODIUM_BOOKING_URL              (shared/fallback)
VITE_PODIUM_BOOKING_URL_KINGSPORT=
VITE_PODIUM_BOOKING_URL_JONESBOROUGH=
# Optional shared/fallback URL used only if a location has no per-location
# default AND no per-location env var:
VITE_PODIUM_BOOKING_URL=

# ── Refill.co online telehealth portal (build-time) ────────────────────────
# Set this to the EXACT Balanced Wellness Refill.co portal URL. There is no
# hardcoded default on purpose: until this is set, every generic telehealth CTA
# on the site safely routes users to /online-care instead of guessing a wrong
# portal URL.
#   e.g. VITE_REFILL_PORTAL_URL=https://app.refill.co/p/your-clinic-slug
VITE_REFILL_PORTAL_URL=
# Optional. Defaults to enabled whenever a valid VITE_REFILL_PORTAL_URL is set.
# Set to "false" to temporarily disable the portal CTAs without removing the URL.
VITE_REFILL_PORTAL_ENABLED=true

# ── Online Care assessment links (build-time, per category) ────────────────
# The /online-care hub shows one card per service category, and each card can
# list MULTIPLE Refill.co assessment options. The provided assessment links are
# hardcoded per category in src/lib/booking.ts (ASSESSMENT_DEFAULTS) — peptides,
# skincare/topicals, men's health (Enclomiphene), and a women's-health topical.
# Weight loss has no GLP-1 assessment yet, so that card safely falls back to
# /book-now.
#
# Adding a new assessment = one entry in ASSESSMENT_DEFAULTS. The env vars below
# are OPTIONAL overrides that prepend a "primary" link to a category (back-compat
# with the earlier single-link model). Precedence per category:
#   1. VITE_REFILL_ASSESSMENT_<CATEGORY>  (prepended as the first option)
#   2. Hardcoded options in src/lib/booking.ts (ASSESSMENT_DEFAULTS)
#   3. No valid option → card falls back to /book-now
VITE_REFILL_ASSESSMENT_WEIGHT_LOSS=
VITE_REFILL_ASSESSMENT_PEPTIDES=
VITE_REFILL_ASSESSMENT_SKINCARE=
VITE_REFILL_ASSESSMENT_WOMENS_HEALTH=
VITE_REFILL_ASSESSMENT_MENS_HEALTH=

# ── Server / deploy ────────────────────────────────────────────────────────
ALLOWED_ORIGIN=*                          # CORS allowlist; set to https://www.balancedmedicalspa.com in prod
CANONICAL_HOST=www.balancedmedicalspa.com # Canonical host; non-canonical (apex or www) requests are 301'd here

# ── Railway sets this automatically ─────────────────────────────────────────
PORT=3000
