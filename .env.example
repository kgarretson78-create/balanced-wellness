# ── Required ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Claude API key (for KelliAI chat)

# ── Optional but recommended ────────────────────────────────────────────────
ELEVENLABS_API_KEY=...                # ElevenLabs key (KelliAI voice)
ELEVENLABS_VOICE_ID=...              # ElevenLabs voice ID

DATABASE_URL=postgresql://user:pass@host:5432/dbname   # Postgres (lead capture)
ADMIN_API_KEY=your-secret-key        # Protects /api/kelliai/leads endpoint

# ── KelliAI integration ────────────────────────────────────────────────────
# Build-time only. Leave unset to use the same-origin "/api" routes shipped
# with this server. Set to an absolute URL (no trailing slash) to point the
# client at a separately hosted KelliAI backend, e.g.:
#   VITE_API_URL=https://kelliai.balancedmedicalspa.com/api
VITE_API_URL=

# ── Booking / scheduling URLs (build-time, per location) ───────────────────
# Each location has a real, dedicated Podium scheduling URL hardcoded as a
# default in src/lib/booking.ts:
#   Kingsport     → https://booking.podium.com/medspa/01930831-564b-7342-98d8-620e43a707e7
#   Jonesborough  → https://booking.podium.com/medspa/019c25c3-bfb8-7652-9b53-3b7f41adc505
#
# The env vars below are optional overrides. Set them in Railway only if you
# want to swap a location's link without a code change. Precedence:
#   1. VITE_PODIUM_BOOKING_URL_<LOCATION>   (per-location override)
#   2. Hardcoded default in src/lib/booking.ts
#   3. VITE_PODIUM_BOOKING_URL              (shared/fallback)
VITE_PODIUM_BOOKING_URL_KINGSPORT=
VITE_PODIUM_BOOKING_URL_JONESBOROUGH=
# Optional shared/fallback URL used only if a location has no per-location
# default AND no per-location env var:
VITE_PODIUM_BOOKING_URL=

# ── Server / deploy ────────────────────────────────────────────────────────
ALLOWED_ORIGIN=*                          # CORS allowlist; set to https://www.balancedmedicalspa.com in prod
CANONICAL_HOST=www.balancedmedicalspa.com # Canonical host; non-canonical (apex or www) requests are 301'd here

# ── Railway sets this automatically ─────────────────────────────────────────
PORT=3000
